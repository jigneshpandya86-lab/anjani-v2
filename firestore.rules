rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Check if the user is an admin by reading their user document
    function isAdmin() {
      return request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Specifically allow anyone to register for notifications (New Collection)
    match /Customer_Notification/{tokenId} {
      allow write: if true;
      allow read: if false; // Clients don't need to read other people's tokens
    }

    // Admins have full read/write access to all collections
    match /{document=**} {
      allow read, write: if isAdmin();
    }

    // Users collection rules for non-admins
    match /users/{userId} {
      // Users can read their own profile to determine their role
      allow read: if request.auth != null && request.auth.uid == userId;
      
      // Users can manage their own FCM tokens for push notifications
      match /tokens/{tokenId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // Orders collection:
    // - All authenticated users (including staff) can read orders
    match /orders/{orderId} {
      allow read: if request.auth != null;
    }
  }
}
