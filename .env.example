# Firebase Configuration
# Get these from Firebase Console > Project Settings
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Firebase Push Notifications
# Get VAPID_PUBLIC_KEY from Firebase Console > Project Settings > Cloud Messaging
VITE_FIREBASE_VAPID_KEY=

# MacroDroid SMS Integration
# Webhook URL for SMS automation (keep secure, do not commit)
VITE_MACRO_URL=

# Business WhatsApp Number
# Used in SMS messages for customer ordering (format: 919925997750)
VITE_BUSINESS_WHATSAPP_NUMBER=

# Google Maps (Client location picker)
VITE_GOOGLE_MAPS_API_KEY=

# Note: GitHub Actions uses these Repository Secrets:
# - FIREBASE_API_KEY
# - FIREBASE_AUTH_DOMAIN
# - FIREBASE_PROJECT_ID
# - FIREBASE_STORAGE_BUCKET
# - FIREBASE_MESSAGING_SENDER_ID
# - FIREBASE_APP_ID
# - VITE_GOOGLE_MAPS_API_KEY
